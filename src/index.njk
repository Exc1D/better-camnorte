      <!-- Contact Section -->
      <section class="section home-contact-section">
        <div class="container">
          <div class="home-section-header">
            <h2 data-i18n="section-contact">Contact Information</h2>
            <a href="contact/" class="home-section-link"
              ><i class="bi bi-arrow-right"></i> <span data-i18n="home-view-all">View All</span></a
            >
          </div>
          <div class="home-contact-v2-grid">
            <a href="tel:0788053581" class="home-contact-v2-card">
