    <!-- Header -->
    {% include "header.njk" %}


    <main id="main-content">
      <!-- Hero Section — Bantayog, the star of the show -->
      <section class="hero" id="hero">
        <div class="hero__inner container">
          <div class="hero__sky">
            <p class="hero__eyebrow" data-i18n="hero-eyebrow">
              <span class="hero__flag" aria-hidden="true"></span>
              See where the money goes · Cost to the people: ₱0
            </p>
            <h1 class="hero__title">
              <span class="hero__title-line hero__title-line--serif">Bantayog</span>
              <span class="hero__title-line hero__title-line--sans">ng Camarines Norte</span>
            </h1>
          </div>

          <!-- The monument stands on the horizon, rising from ground into sky -->
          <img
            class="hero__monument"
            src="assets/images/banners/bantayog.png"
            alt="The provincial monument to José Rizal, a symbol of Camarines Norte"
            width="480"
            height="600"
            fetchpriority="high"
          />
        </div>

        <!-- GROUND: the institutional band the province stands on -->
        <div class="hero__earth">
          <div class="hero__earth-inner container">
            <p class="hero__horizon-label">
              <span class="hero__horizon-star" aria-hidden="true">★</span>
              Seventeen goals, one province
            </p>
            <p class="hero__lede" data-i18n="hero-subtitle">
              An independent watchdog showing how Camarines Norte spends public money —
              every figure sourced and dated.
            </p>

            <p class="hero__stat">
              <a href="/budget/#dpwh">
                <strong>₱409.5M</strong> across <strong>63</strong> DPWH projects tracked
              </a>
              <span class="hero__stat-src">Source: DPWH — Camarines Norte District Engineering Office</span>
            </p>

            <div class="hero__actions">
              <a href="/budget/" class="hero__btn hero__btn--primary" data-i18n="hero-cta-primary">
                Explore the budget
                <i class="bi bi-arrow-right" aria-hidden="true"></i>
              </a>
              <a href="/budget/#dpwh" class="hero__btn hero__btn--ghost" data-i18n="hero-cta-secondary"
                >How we source this</a
              >
            </div>

          </div>
        </div>
      </section>

      <!-- Appointment Services CTA -->
      <section class="appointment-cta-section" aria-label="Governor's Office Appointment Services">
        <div class="container">
          <div class="appointment-cta-inner">
            <div class="appointment-cta-animation" aria-hidden="true">
              <dotlottie-player
                src="assets/animation/ramonloganjr-booking.json"
                background="transparent"
                speed="1"
                loop
                autoplay
              ></dotlottie-player>
            </div>
            <div class="appointment-cta-content">
              <h2 class="appointment-cta-heading" data-i18n="appointment-cta-heading">
                Enhancing Appointment Services of Camarines Norte Provincial Government Governor's Office
              </h2>
              <p class="appointment-cta-subtitle" data-i18n="appointment-cta-subtitle">
                No lines. No back-and-forth. Just efficient appointments.
              </p>
              <div class="appointment-cta-actions">
                <a
                  href="https://camnortemayorsoffice-oasys.com/user/auth/login.php"
                  class="appointment-cta-btn appointment-cta-btn--primary"
                  target="_blank"
                  rel="noopener noreferrer"
                  ><i class="bi bi-calendar-check" aria-hidden="true"></i>
                  <span data-i18n="home-schedule-appointment">Schedule Appointment</span></a
                >
                <a
                  href="https://camnortemayorsoffice-oasys.com/user/auth/register.php"
                  class="appointment-cta-btn appointment-cta-btn--outline"
                  target="_blank"
                  rel="noopener noreferrer"
                  ><i class="bi bi-person-plus" aria-hidden="true"></i>
                  <span data-i18n="home-create-account">Create Account</span></a
                >
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Government services live on the official LGU site (see redesign Principle 1) -->
      <section class="section home-services-section">
        <div class="container">
          <div class="home-section-header">
            <h2>Looking for a government service?</h2>
            <p>
              Requirements, fees, and processing times for provincial services are published in the
              official Citizen's Charter of Camarines Norte.
            </p>
            <a
              href="https://camsnorte.com/citizens-charter/"
              class="home-section-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span>Official Citizen's Charter</span>
              <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
            </a>
          </div>
        </div>
      </section>

