      <div class="container">
        <div class="hotline-inner">
          <div class="hotline-items">
            <a href="tel:09274008033" class="hotline-item">
              <i class="bi bi-shield-fill" aria-hidden="true"></i>
              <span>Police: 0927 400 8033</span>
            </a>
            <a href="tel:09162840885" class="hotline-item">
              <i class="bi bi-heart-fill" aria-hidden="true"></i>
              <span>MSWDO: 0916 284 0885</span>
            </a>
            <a href="tel:09360620305" class="hotline-item">
              <i class="bi bi-fire" aria-hidden="true"></i>
              <span>Fire: 0936 062 0305</span>
            </a>
            <a href="tel:0906188086" class="hotline-item">
              <i class="bi bi-building" aria-hidden="true"></i>
              <span>DILG: 0906 188 086</span>
            </a>
            <a href="tel:09263833744" class="hotline-item">
              <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
              <span>MDRRMO: 0926 383 3744</span>
            </a>
            <a href="tel:09068195569" class="hotline-item">
              <i class="bi bi-truck" aria-hidden="true"></i>
