              <div class="home-stat-card-content">
                <span class="home-stat-card-value">12</span>
                <span class="home-stat-card-label" data-i18n="home-barangays">Municipalities</span>
                <span class="home-stat-card-source" data-i18n="home-administrative-units"
                  >Administrative Units</span
                >
              </div>
            </a>
            <a href="budget/" class="home-stat-card">
              <div class="home-stat-card-icon"><i class="bi bi-award-fill"></i></div>
              <div class="home-stat-card-content">
                <span class="home-stat-card-value" data-i18n="home-1st-class">1st Class</span>
                <span class="home-stat-card-label" data-i18n="home-municipality">Municipality</span>
                <span class="home-stat-card-source" data-i18n="home-income-classification"
