      <!-- Location Section -->
      <section class="section weather-map-section">
        <div class="container">
          <div class="home-stats-v2-header">
            <h2 data-i18n="home-weather-and-map-of-camnorte">Map of Camarines Norte</h2>
          </div>
          <div class="weather-map-grid">
            <div class="map-column">
              <div class="map-card">
                <div
                  id="map-container"
                  role="application"
                  aria-label="Interactive map of Camarines Norte"
                  data-map-loaded="iframe"
                >
                  <iframe
                    id="osm-embed"
                    class="map-iframe"
                    src="https://www.openstreetmap.org/export/embed.html?bbox=122.9353%2C14.0972%2C122.9753%2C14.1272&layer=mapnik&marker=14.1122%2C122.9553"
                    title="Map of Camarines Norte"
                    loading="lazy"
                    aria-label="OpenStreetMap showing Camarines Norte Provincial Capitol, Camarines Norte"
                  ></iframe>
                </div>
                <p class="map-attribution">
                  <i class="bi bi-geo-alt" aria-hidden="true"></i>
                  <span data-i18n="home-camnorte-municipal-hall-camarines-norte-3708"
                    >Camarines Norte Provincial Capitol, Camarines Norte 3708</span
                  >
                </p>
                <p class="sr-only" data-i18n="home-interactive-map-showing-the-location-of-camnorte">
