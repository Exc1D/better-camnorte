    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "BetterCamNorte",
        "url": "https://bettercamnorte.org",
        "logo": "https://bettercamnorte.org/assets/images/logo/camnorte-logo.png",
        "description": "Independent, citizen-led public-spending transparency project tracking where Camarines Norte's public money goes. Not an official website of the Provincial Government of Camarines Norte.",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Provincial Capitol",
          "addressLocality": "Camarines Norte",
          "addressRegion": "Camarines Norte",
          "postalCode": "3708",
          "addressCountry": "PH"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "14.1122",
          "longitude": "122.9553"
        },
        "telephone": "(078) 326-5000",
        "email": "services@camnorte.gov.ph",
        "openingHours": "Mo-Fr 08:00-17:00",
        "areaServed": {
          "@type": "AdministrativeArea",
          "name": "Camarines Norte"
        },
        "sameAs": ["https://www.facebook.com/piocamnorte", "https://camnorte.gov.ph"]
      }
    </script>
    <script type="application/ld+json">
