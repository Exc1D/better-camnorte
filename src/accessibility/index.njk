      <!-- Page Header -->
      <section class="page-header">
        <div class="container">
          <div class="page-header-content">
            <span class="page-header-badge"
              ><i class="bi bi-universal-access"></i>
              <span data-i18n="a11y-accessibility">Accessibility</span></span
            >
            <h1 data-i18n="access-title">Accessibility Statement</h1>
            <p class="page-header-desc" data-i18n="access-subtitle">
              Our commitment to digital accessibility for all citizens
            </p>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div class="a11y-container">
            <!-- Conformance Badge -->
            <div class="a11y-badge-section">
              <div class="a11y-conformance-badge">
                <i class="bi bi-check-circle-fill"></i>
                <div>
                  <span class="a11y-badge-label" data-i18n="a11y-wcag-21-level-aa"
                    >WCAG 2.1 Level AA</span
                  >
                  <span class="a11y-badge-text" data-i18n="a11y-conformant">Conformant</span>
                </div>
              </div>
            </div>

            <!-- Commitment Section -->
            <div class="a11y-section">
              <h2 data-i18n="access-commitment">Our Commitment</h2>
              <p data-i18n="a11y-better-camnorte-is-committed-to-ensuring-digital">
                BetterCamNorte is committed to ensuring digital accessibility for people with
                disabilities. We are continually improving the user experience for everyone and
                applying the relevant accessibility standards.
              </p>
            </div>

            <!-- Features Grid -->
            <div class="a11y-section">
              <h2 data-i18n="access-features">Accessibility Features</h2>
              <div class="a11y-features-grid">
                <div class="a11y-feature">
                  <i class="bi bi-keyboard"></i>
                  <h3 data-i18n="a11y-keyboard-navigation">Keyboard Navigation</h3>
                  <p data-i18n="a11y-all-functionality-available-using-only-a-keyboard">
                    All functionality available using only a keyboard.
                  </p>
                </div>
                <div class="a11y-feature">
                  <i class="bi bi-eye"></i>
                  <h3 data-i18n="a11y-screen-reader-support">Screen Reader Support</h3>
                  <p data-i18n="a11y-compatible-with-jaws-nvda-and-voiceover">
                    Compatible with JAWS, NVDA, and VoiceOver.
                  </p>
                </div>
                <div class="a11y-feature">
                  <i class="bi bi-type"></i>
                  <h3 data-i18n="a11y-text-alternatives">Text Alternatives</h3>
                  <p data-i18n="a11y-all-images-have-descriptive-alt-text">
                    All images have descriptive alt text.
                  </p>
                </div>
                <div class="a11y-feature">
                  <i class="bi bi-palette"></i>
                  <h3 data-i18n="a11y-color-contrast">Color Contrast</h3>
                  <p data-i18n="a11y-meets-wcag-aa-contrast-requirements">
                    Meets WCAG AA contrast requirements.
                  </p>
                </div>
                <div class="a11y-feature">
                  <i class="bi bi-phone"></i>
                  <h3 data-i18n="a11y-responsive-design">Responsive Design</h3>
                  <p data-i18n="a11y-works-on-all-devices-and-screen-sizes">
                    Works on all devices and screen sizes.
                  </p>
                </div>
                <div class="a11y-feature">
                  <i class="bi bi-hourglass-split"></i>
                  <h3 data-i18n="a11y-no-time-limits">No Time Limits</h3>
                  <p data-i18n="a11y-no-time-limits-on-reading-or-interacting">
                    No time limits on reading or interacting.
                  </p>
                </div>
              </div>
            </div>

            <!-- Known Limitations -->
            <div class="a11y-section">
              <h2 data-i18n="access-limitations">Known Limitations</h2>
              <ul class="a11y-list">
                <li>
                  <i class="bi bi-exclamation-circle"></i>
                  <span data-i18n="a11y-some-pdf-documents-may-not-be-fully-accessible-to"
                    >Some PDF documents may not be fully accessible to screen readers</span
                  >
                </li>
                <li>
                  <i class="bi bi-exclamation-circle"></i>
                  <span data-i18n="a11y-some-thirdparty-embedded-content-may-have"
                    >Some third-party embedded content may have accessibility issues</span
                  >
                </li>
              </ul>
            </div>

            <!-- Alternative Access -->
            <div class="a11y-section">
              <h2 data-i18n="access-alternative">Alternative Access</h2>
              <p data-i18n="a11y-if-you-encounter-difficulty-accessing-any">
                If you encounter difficulty accessing any information, contact us:
              </p>
              <div class="a11y-contact-grid">
                <a href="mailto:volunteer@bettercamnorte.org" class="a11y-contact-item"
                  ><i class="bi bi-envelope-fill"></i>
                  <span data-i18n="a11y-volunteerbettercamnorteorg"
                    >volunteer@bettercamnorte.org</span
                  ></a
                >
              </div>
            </div>

            <!-- Technical Info -->
            <div class="a11y-section">
              <h2 data-i18n="access-technical">Technical Specifications</h2>
              <div class="a11y-tech-tags">
                <span class="a11y-tag" data-i18n="a11y-html5">HTML5</span>
                <span class="a11y-tag" data-i18n="a11y-css3">CSS3</span>
                <span class="a11y-tag" data-i18n="a11y-javascript">JavaScript</span>
                <span class="a11y-tag" data-i18n="a11y-react">React</span>
                <span class="a11y-tag" data-i18n="a11y-typescript">TypeScript</span>
                <span class="a11y-tag">ARIA</span>
              </div>
            </div>

            <!-- Promise Card -->
            <div class="a11y-promise">
              <i class="bi bi-heart-fill"></i>
              <div>
                <h3 data-i18n="access-promise">Our Promise</h3>
                <p data-i18n="a11y-better-camnorte-is-committed-to-ensuring-that-our">
                  BetterCamNorte is committed to ensuring that our digital services are accessible to
                  all citizens, regardless of ability. We view accessibility not as a feature, but
                  as a fundamental right.
                </p>
              </div>
            </div>

            <p class="a11y-date" data-i18n="a11y-last-updated-november-29-2025">
              Last updated: November 29, 2025
            </p>
          </div>
        </div>
      </section>
