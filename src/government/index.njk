                  <span><i class="bi bi-telephone"></i> (078) 326-5014</span>
                  <span
                    ><i class="bi bi-envelope"></i>
                    <span data-i18n="gov-mswdocamnortegovph">mswdo@camnorte.gov.ph</span></span
                  >
                </div>
              </div>
            </div>
            <div class="dept-card">
