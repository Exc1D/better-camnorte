                  <span><i class="bi bi-telephone"></i> (078) 326-5012</span>
                  <span
                    ><i class="bi bi-envelope"></i>
                    <span data-i18n="gov-treasurercamnortegovph">treasurer@camnorte.gov.ph</span></span
                  >
                </div>
              </div>
            </div>
            <div class="dept-card">
              <div class="dept-card-icon"><i class="bi bi-building-fill-gear"></i></div>
              <div class="dept-card-content">
                <h4 class="dept-card-title" data-i18n="gov-municipal-engineering-office">
