    <!-- Header -->
    {% include "header.njk" %}


    <main id="main-content">
      <!-- Breadcrumbs -->
      <div class="container">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href="../" data-i18n="gov-home">Home</a>
          <span>/</span>
          <span aria-current="page">Government</span>
        </nav>
      </div>

      <!-- Page Header -->
      <section class="page-header">
        <div class="container">
          <div class="page-header-content">
            <span class="page-header-badge"
              ><i class="bi bi-building-fill"></i>
              <span data-i18n="gov-government">Government</span></span
            >
            <h1 data-i18n="gov-title">Government Structure & Officials</h1>
            <p class="page-header-desc" data-i18n="gov-subtitle">
              Meet the leadership and offices serving Camarines Norte
            </p>
          </div>
        </div>
      </section>

      <!-- Executive Branch -->
      <section class="section" style="background: var(--color-bg-alt)">
        <div class="container">
          <!-- Section Header -->
          <div class="text-center" style="margin-bottom: var(--spacing-xl)">
            <span
              style="
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: linear-gradient(
                  135deg,
                  var(--color-primary) 0%,
                  var(--color-secondary) 100%
                );
                color: white;
                padding: 8px 20px;
                border-radius: 50px;
                font-size: 0.875rem;
                margin-bottom: var(--spacing-sm);
              "
              ><i class="bi bi-star-fill"></i>
              <span data-i18n="gov-executive-branch">Executive Branch</span></span
            >
            <h3
              data-i18n="gov-executive"
              style="font-size: 1.75rem; margin-bottom: var(--spacing-xs)"
            >
              Provincial Leadership
            </h3>
            <p
              style="color: var(--color-text-light)"
              data-i18n="gov-the-executive-officials-leading-camnortes-governance"
            >
              The executive officials leading Camarines Norte's governance
            </p>
          </div>

          <!-- Executive Cards -->
          <div style="max-width: 460px; margin: 0 auto">
            <!-- Provincial Governor Card -->
            <div class="executive-card">
              <div class="executive-card-header">
                <img
                  class="executive-photo"
                  src="../assets/images/officials/padilla-gov.jpg"
                  alt="Governor Ricarte R. Padilla"
                  width="88"
                  height="88"
                  loading="lazy"
                  style="width: 88px; height: 88px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto var(--spacing-sm); border: 3px solid rgba(255, 255, 255, 0.85)"
                />
                <span class="executive-badge" data-i18n="title-mayor">Provincial Governor</span>
                <h4 class="executive-name">
                  Governor Ricarte R. Padilla
                </h4>
              </div>
              <div class="executive-card-body">
                <div class="executive-contacts">
                  <a href="mailto:pgcamarinesnorte@gmail.com"
                    ><i class="bi bi-envelope"></i>
                    <span data-i18n="gov-mayorcamnortegovph">pgcamarinesnorte@gmail.com</span></a
                  >
                  <a href="https://camsnorte.com/"><i class="bi bi-telephone"></i> Provincial Capitol, Brgy III, Daet</a>
                  <span><i class="bi bi-clock"></i> Mon-Fri: 8:00 AM - 5:00 PM</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Provincial Board -->
      <section class="section">
        <div class="container">
          <!-- Section Header -->
          <div class="text-center" style="margin-bottom: var(--spacing-xl)">
            <span
              style="
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: linear-gradient(135deg, var(--color-success) 0%, #05c793 100%);
                color: white;
                padding: 8px 20px;
                border-radius: 50px;
                font-size: 0.875rem;
                margin-bottom: var(--spacing-sm);
              "
              ><i class="bi bi-people-fill"></i>
              <span data-i18n="gov-legislative-branch">Legislative Branch</span></span
            >
            <h3
              data-i18n="gov-sb-members"
              style="font-size: 1.75rem; margin-bottom: var(--spacing-xs)"
            >
              Sangguniang Panlalawigan Members
            </h3>
            <p data-i18n="gov-sb-subtitle" style="color: var(--color-text-light)">
              Provincial Board members serving the people of Camarines Norte
            </p>
          </div>

          <!-- Presiding Officer · Vice Governor -->
          <div style="max-width: 460px; margin: 0 auto var(--spacing-xl)">
            <div class="executive-card">
              <div class="executive-card-header">
                <img
                  class="executive-photo"
                  src="../assets/images/officials/ascutia.png"
                  alt="Vice Governor Joseph V. Ascutia"
                  width="88"
                  height="88"
                  loading="lazy"
                  style="width: 88px; height: 88px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto var(--spacing-sm); border: 3px solid rgba(255, 255, 255, 0.85)"
                />
                <span class="executive-badge">Presiding Officer · Vice Governor</span>
                <h4 class="executive-name">
                  Vice Governor Joseph V. Ascutia
                </h4>
              </div>
              <div class="executive-card-body">
                <div class="executive-contacts">
                  <a href="mailto:pgcamarinesnorte@gmail.com"
                    ><i class="bi bi-envelope"></i>
                    <span data-i18n="gov-vicemayorcamnortegovph">pgcamarinesnorte@gmail.com</span></a
                  >
                  <a href="https://camsnorte.com/"><i class="bi bi-telephone"></i> Provincial Capitol, Brgy III, Daet</a>
                  <span><i class="bi bi-clock"></i> Mon-Fri: 8:00 AM - 5:00 PM</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Roster grouped by district · presided over by Vice Governor Joseph V. Ascutia -->
          {% set spGroups = [
            { title: "1st District", members: [
              { name: "Hon. Jhon Carlo V. Delima", photo: "delima.jpg" },
              { name: "Hon. Winifredo B. Oco", photo: "oco.png" },
              { name: "Hon. Arthur Michael Canlas", photo: "canlas.jpg" },
              { name: "Hon. Junjun Enova", photo: "enova.jpg" },
              { name: "Hon. Teresita Malubay", photo: "malubay.jpg" }
            ] },
            { title: "2nd District", members: [
              { name: "Hon. Dennis L. Riel", photo: "riel.jpg" },
              { name: "Hon. Arnulfo Balane", photo: "balane.jpg" },
              { name: "Hon. Jonah G. Pimentel", photo: "pimentel.jpg" },
              { name: "Hon. Rodolfo V. Gache", photo: "gache.jpg" },
              { name: "Hon. Renee Herrera", photo: "herrera.jpg" }
            ] },
            { title: "Ex-Officio Members", members: [
              { name: "Hon. Rey Kenneth N. Oning", role: "PCL President", photo: "oning.png" },
              { name: "Hon. Rebecca Padilla", role: "ABC / Liga ng mga Barangay President", photo: "padilla.jpg", variant: "liga" },
              { name: "Hon. Ricky S. Noblesala", role: "IP Representative", photo: "noblesala.jpg", variant: "ipmr" },
              { name: "Hon. Mary Joy P. Carranza", role: "SK Federation President", photo: "carranza.jpg", variant: "sk" }
            ] }
          ] %}
          {% for g in spGroups %}
          <h4 class="councilor-group-title text-center" style="margin: var(--spacing-lg) 0 var(--spacing-sm); color: var(--color-primary)">
            {{ g.title }}
          </h4>
          <div class="councilor-grid">
            {% for m in g.members %}
            <div class="councilor-card{% if m.variant %} councilor-card--{{ m.variant }}{% endif %}">
              <img
                class="councilor-photo"
                src="../assets/images/officials/{{ m.photo }}"
                alt="{{ m.name }}"
                width="96"
                height="96"
                loading="lazy"
                style="width: 96px; height: 96px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto var(--spacing-xs)"
              />
              <h4 class="councilor-name">{{ m.name }}</h4>
              <span class="councilor-badge{% if m.variant %} councilor-badge--{{ m.variant }}{% endif %}">{{ m.role or "Board Member" }}</span>
            </div>
            {% endfor %}
          </div>
          {% endfor %}
          <p class="text-center" style="margin-top: var(--spacing-lg); font-size: 0.875rem; color: var(--color-text-light)">
            <i class="bi bi-info-circle" aria-hidden="true"></i>
            Source:
            <a href="https://camsnorte.com/the-sanggunian/" target="_blank" rel="noopener noreferrer"
              >Sangguniang Panlalawigan ng Camarines Norte</a
            >
            — as of June 2026
          </p>
        </div>
      </section>

      <!-- Department Heads -->
