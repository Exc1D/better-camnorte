                <div class="dept-card-contacts">
                  <span><i class="bi bi-telephone"></i> (078) 326-5015</span>
                  <span
                    ><i class="bi bi-envelope"></i>
                    <span data-i18n="gov-agricamnortegovph">agri@camnorte.gov.ph</span></span
                  >
                </div>
              </div>
            </div>
            <div class="dept-card">
              <div class="dept-card-icon"><i class="bi bi-clipboard-data-fill"></i></div>
