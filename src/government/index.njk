                <div class="dept-card-contacts">
                  <span><i class="bi bi-telephone"></i> (078) 326-5016</span>
                  <span
                    ><i class="bi bi-envelope"></i>
                    <span data-i18n="gov-mpdocamnortegovph">mpdo@camnorte.gov.ph</span></span
