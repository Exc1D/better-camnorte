{
  "name": "bettercamnorte-web",
  "version": "1.1.25",
  "description": "BetterCamNorte - independent, citizen-led public-spending transparency tracker for Camarines Norte (not an official government site)",
  "scripts": {
    "dev": "python3 -m http.server 8000",
    "sync:dpwh": "node scripts/sync-dpwh-camarines-norte.mjs",
    "build": "npm run sync:dpwh && bash build.sh",
    "build:offline": "bash build.sh",
    "build:major": "bash scripts/version.sh major && npm run sync:dpwh && bash build.sh --no-bump",
    "build:minor": "bash scripts/version.sh minor && npm run sync:dpwh && bash build.sh --no-bump",
    "serve": "python3 -m http.server 8000",
    "serve:dist": "cd dist && python3 -m http.server 8080",
    "version:major": "node scripts/bump-version.js major",
    "version:minor": "node scripts/bump-version.js minor",
    "version:patch": "node scripts/bump-version.js patch",
    "version:check": "node scripts/bump-version.js",
    "lighthouse": "lhci autorun",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "camnorte",
    "camarines-norte",
    "government",
    "lgu"
  ],
  "author": "Ramon Logan Jr.",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@babel/cli": "^7.23.9",
    "@babel/core": "^7.29.6",
    "@babel/preset-env": "^7.23.9",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "clean-css-cli": "^5.6.3",
    "core-js": "^3.40.0",
    "html-minifier-terser": "^7.2.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.1",
    "terser": "^5.44.1"
  },
  "overrides": {
    "tmp": "0.2.7",
    "js-yaml": "^4.2.0",
    "uuid": "^11.1.1"
  }
}
